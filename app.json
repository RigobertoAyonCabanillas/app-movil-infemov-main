{
  "expo": {
    "name": "Fixskale",
    "slug": "fixskale-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logoFixskaleFMovil.png",
    "scheme": "fixskale-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.infemov.appmovil",
      "supportsTablet": true,
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["fixskale-app"]
          }
        ]
      }
    },
    "android": {
      "package": "com.infemov.appmovil",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": {
            "scheme": "fixskale-app"
          },
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#7A8C99",
        "foregroundImage": "./assets/images/FSLogo.png",
        "backgroundImage": "./assets/images/FSLogo.png",
        "monochromeImage": "./assets/images/FSLogo.png"
      },
      "usesCleartextTraffic": true,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },


    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "@react-native-google-signin/google-signin",
      "expo-router",
      ["expo-sqlite", { "enableChangeListener": true }],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logoPoweredByFixskale.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-sqlite",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "207cdd5d-9cd1-471d-866e-944284f3ce27"
      }
    }
  }
}
